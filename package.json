{
  "name": "amoxtli-vue-2",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144\" nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "npx wrangler pages dev dist",
    "typecheck": "nuxt typecheck",
    "prepare": "nuxt prepare",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "invites:generate": "npx tsx scripts/generate-invites.ts invites.yaml",
    "invites:override": "npx tsx scripts/generate-invites.ts invites.yaml --override",
    "invites:publish": "npx wrangler kv bulk put --binding AMVI_KV invites-batch.json --remote",
    "invites:publish-local": "npx wrangler kv bulk put --binding AMVI_KV invites-batch.json",
    "invites:list-remote": "npx wrangler kv key list --namespace-id=b9f605b548ca4b7b8bd1055c274bd9db --remote > invites-in-remote.json",
    "invites:list-local": "npx wrangler kv key list --namespace-id=b9f605b548ca4b7b8bd1055c274bd9db",
    "invites:purge-remote": "npx wrangler kv bulk delete invites-in-remote.json --namespace-id=b9f605b548ca4b7b8bd1055c274bd9db --remote",
    "invites:diff": "pnpm run invites:list-remote && npx tsx scripts/invites-diff.ts"
  },
  "dependencies": {
    "@ark-ui/vue": "catalog:frontend",
    "@shikijs/core": "catalog:frontend",
    "@shikijs/monaco": "catalog:frontend",
    "@shikijs/twoslash": "catalog:frontend",
    "@volar/monaco": "catalog:frontend",
    "@vue/language-service": "catalog:frontend",
    "@webcontainer/api": "catalog:frontend",
    "@xterm/addon-fit": "catalog:frontend",
    "@xterm/xterm": "catalog:frontend",
    "birpc": "catalog:frontend",
    "clsx": "catalog:frontend",
    "dexie": "catalog:frontend",
    "floating-vue": "catalog:frontend",
    "fuse.js": "catalog:frontend",
    "jszip": "catalog:frontend",
    "licia": "catalog:frontend",
    "luna-console": "catalog:frontend",
    "monaco-editor": "catalog:frontend",
    "monaco-editor-core": "catalog:frontend",
    "motion-v": "catalog:frontend",
    "pathe": "catalog:frontend",
    "reka-ui": "catalog:frontend",
    "shiki": "catalog:frontend",
    "shiki-magic-move": "catalog:frontend",
    "strip-json-comments": "catalog:frontend",
    "theme-vitesse": "catalog:frontend",
    "twoslash-vue": "catalog:frontend",
    "vscode-uri": "catalog:frontend",
    "vue": "catalog:frontend",
    "vue-router": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@iconify-json/carbon": "catalog:icons",
    "@iconify-json/catppuccin": "catalog:icons",
    "@iconify-json/logos": "catalog:icons",
    "@iconify-json/mynaui": "catalog:icons",
    "@iconify-json/ph": "catalog:icons",
    "@iconify-json/svg-spinners": "catalog:icons",
    "@intlify/eslint-plugin-vue-i18n": "catalog:dev",
    "@nuxt/content": "catalog:nuxt",
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/eslint": "catalog:nuxt",
    "@nuxt/icon": "catalog:nuxt",
    "@nuxt/image": "catalog:nuxt",
    "@nuxt/kit": "catalog:nuxt",
    "@nuxt/scripts": "catalog:nuxt",
    "@nuxtjs/color-mode": "catalog:nuxt",
